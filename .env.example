# Reference only - set these on the **agent** service in your Avassa application spec
# (or via Strongbox / application variables).
#
# vLLM (default in application.example.yaml):
#   LOCAL_LLM_BASE=http://local-llm:8000/v1
#   LOCAL_MODEL=Qwen/Qwen2.5-0.5B-Instruct
#
# Ollama on the site (see avassa/application.ollama.example.yaml):
#   LOCAL_LLM_BASE=http://<ollama-host>:11434/v1
#   LOCAL_MODEL=llama3.2   # or any pulled model name
#
# OPENAI_API_KEY=   # optional; enables ask_cloud_llm and cloud fallback
# CLOUD_MODEL=gpt-4o-mini
